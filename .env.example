# -----------------------------------------------------------
# Auth (email/password – each user has an app account)
# -----------------------------------------------------------
# Required. Generate with: npx auth secret (or node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=
# Public origin for NextAuth and Amazon OAuth redirect_uri (no trailing slash), e.g. https://yourdomain.com
# NEXTAUTH_URL=http://localhost:3000

# Forgot-password emails (Resend API – https://resend.com). In production, set both or reset emails will fail.
# EMAIL_FROM must be a verified sender/domain in Resend.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=HIGH FOCUS <reset@yourdomain.com>
# Optional: password reset link lifetime in hours (default 1)
# PASSWORD_RESET_EXPIRY_HOURS=1

# Database for user accounts (SQLite – file created in prisma/ by migrate)
DATABASE_URL="file:./dev.db"
# If you override DATABASE_URL in .env.local, `prisma db seed` loads .env.local too (see prisma/loadEnv.ts) so promos
# land in the same file Next.js uses. Mismatch = every promo looks "invalid" in the app.
# DANGER: npm run db:reset-all sets FULL_ENV_RESET and runs seed — deletes EVERY user and EVERY promo code, then mints fresh HF- tester codes. Do not run against production unless you mean it.
# FULL_ENV_RESET=true
# Safer: npm run db:reset-promos — deletes all promo codes + redemptions only, remints HF- batch (bump OPAQUE_SEED_LABEL in prisma/seed.ts for a new list). Keeps users.
# RESET_PROMOS_ONLY=true

# -----------------------------------------------------------
# Amazon SP-API credentials
# -----------------------------------------------------------
# LWA OAuth client (required for token exchange / runtime)
SP_API_CLIENT_ID=amzn1.application-oa2-client.xxxxx
SP_API_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Self-authorization only: refresh token + seller from one account (optional if every user uses Connect Amazon OAuth)
SP_API_REFRESH_TOKEN=Atzr|IwEBxxxxxxxxxxxxxxxxxxxxxxxx

# Public SP-API app — website OAuth (register these exact URLs in Developer Central)
# Application ID from "Edit App" (amzn1.sellerapps.app.xxxxx)
SP_API_APPLICATION_ID=
# Draft app testing: SP_API_OAUTH_DRAFT=true adds version=beta on consent + confirm redirects
# SP_API_OAUTH_DRAFT=true
# Optional: override Seller Central host (default follows marketplace in Settings)
# SP_API_OAUTH_CONSENT_BASE=https://sellercentral.amazon.com
# Login URI:  {APP_BASE}/api/amazon/oauth/login
# Redirect URI: {APP_BASE}/api/amazon/oauth/callback

# Seller + marketplace (required for server-wide / self-auth mode; per-user OAuth supplies seller per account)
SELLER_ID=A1ABCDEF2GHIJK
MARKETPLACE_ID=ATVPDKIKX0DER

# Region + endpoint (required/optional)
AWS_REGION=us-east-1
SP_API_HOST=sellingpartnerapi-na.amazon.com

# -----------------------------------------------------------
# AWS signing credentials
# -----------------------------------------------------------
# If your key starts with AKIA (long-lived IAM user key):
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_SESSION_TOKEN=

# If your key starts with ASIA (temporary STS key):
# - keep AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# - and you MUST set AWS_SESSION_TOKEN to the full token value
#AWS_SESSION_TOKEN=IQoJb3JpZ2luX2VjE...

# Optional: assume role instead of direct signing keys
AWS_ROLE_ARN=
AWS_ROLE_SESSION_NAME=next-sp-api-session

# -----------------------------------------------------------
# Product Advertising API (optional – for main product-page BSR)
# -----------------------------------------------------------
# Get keys from Amazon Associates / Product Advertising API.
# If set, BSR will be the main category rank shown on the product page; otherwise SP-API subcategory rank is used.
# PA_API_ACCESS_KEY=
# PA_API_SECRET_KEY=
# PA_API_PARTNER_TAG=your-associate-tag-20

# -----------------------------------------------------------
# Billing: trial, Stripe subscription, promo codes
# -----------------------------------------------------------
# Stripe subscription trial in days (default 14) for Checkout — card on file; first charge when trial ends.
# New accounts do not get a separate free app trial; access starts after payment or a promo code (see /get-access).
SUBSCRIPTION_TRIAL_DAYS=14
# Shown on /get-access (marketing only — set to match your Stripe recurring Price, e.g. $19.95/month)
BILLING_PRICE_DISPLAY=$19.95/month
# Set to true/1/yes to skip all subscription checks (local dev only)
# BILLING_DISABLED=true
# While QA'ing with real billing rules: everyone gets access. Remove or set false to require trial / promo / Stripe only.
# TESTING_BILLING_PASS=true
# Pause paid Stripe checkout but keep promo + sign-in (testing phase; show “do not pay” notice). Set false when you sell.
# SUBSCRIPTIONS_PAUSED=true
# Optional override for the notice (otherwise a default message is used).
# SUBSCRIPTIONS_PAUSED_MESSAGE=We are not accepting paid subscribers yet. Please do not pay. Use your invite promo code.
# Owner email: always has app access (no subscription). Optional seed user: APP_OWNER_PASSWORD + APP_OWNER_NAME.
# APP_OWNER_EMAIL=you@example.com
# APP_OWNER_PASSWORD=
# APP_OWNER_NAME=
# Personal invite code: matches this exact string (after trim/uppercase). First use on a deployment creates the DB row
# automatically — you do not have to run seed in production. PromoCode.expiresAt=null; grants APP_OWNER_PROMO_GRANT_DAYS
# per signup (default 36500 ≈ 100y). Keep secret.
# APP_OWNER_PROMO_CODE=HF-OWNER
# APP_OWNER_PROMO_GRANT_DAYS=36500
# Opaque HF-… codes from `prisma db seed` exist only in that database. Codes printed on your laptop are invalid on
# production until you seed that server or insert those rows in the production DB.
# --- Stripe (payment access) ---
# 1) Dashboard → Developers → API keys → copy Secret key (test: sk_test_…).
# 2) Products → Add product → add a recurring Price (e.g. $19.95/month) → copy Price ID (price_…).
# 3) Webhooks (local): install Stripe CLI, run: npm run stripe:webhook
#    Copy the "whsec_…" line into STRIPE_WEBHOOK_SECRET below. Leave that terminal open while testing.
# 4) Production (LIVE keys): Use Dashboard toggle “Test mode” OFF. Create/view live Secret key (sk_live_…),
#    live Price IDs, and a **separate** webhook endpoint for https://YOUR_DOMAIN/api/billing/webhook (do not
#    reuse the test-mode webhook secret). Subscribe to at least: checkout.session.completed,
#    customer.subscription.created, customer.subscription.updated, customer.subscription.deleted (add
#    invoice.* later if you add dunning emails in-app.)
# 5) Customer portal (Manage billing): Dashboard → Settings → Billing → Customer portal → activate and
#    configure allowed actions (cancel, update payment method). Portal return URL should be your app origin.
# 6) App URLs: Set NEXTAUTH_URL (and APP_BASE_URL if you use it) to the **public HTTPS** origin with no
#    trailing slash—e.g. https://yourdomain.com—so Stripe success/cancel URLs and OAuth redirects match
#    what users see in the browser (localhost values will break production checkout returns).
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=price_xxxxxxxx
STRIPE_WEBHOOK_SECRET=
# Optional explicit app URL for checkout redirects (defaults to NEXTAUTH_URL)
# APP_BASE_URL=https://yourdomain.com
# Tester promos: npx prisma db seed → opaque HF-… codes (single-use each; give one code per person)

# -----------------------------------------------------------
# App behavior
# -----------------------------------------------------------
# Browser tab / default document title (optional). If unset, a built-in default is used.
# NEXT_PUBLIC_APP_TITLE=My Sourcing App
# Shown on login, get-access, and subscribe (mailto link). Omit to hide the line.
# SUPPORT_EMAIL=help@yourdomain.com
RESTRICTED_BRANDS=NIKE,APPLE,LEGO
PROJECTED_MONTHLY_UNITS=30
BATCH_ANALYZE_CONCURRENCY=6
# Max Catalog Items returned per explorer search request (limits SP-API GETs; server clamps client page size)
# CATALOG_SEARCH_MAX_PAGE_SIZE=60
# SP-API response cache TTLs (seconds)
# SP_API_CACHE_CATALOG_SEARCH_TTL_SEC=600
# SP_API_CACHE_CATALOG_ITEM_TTL_SEC=3600
# SP_API_CACHE_KEYWORD_SEARCH_TTL_SEC=600
# SP_API_CACHE_ANALYSIS_TTL_SEC=600
# SP_API_CACHE_RESTRICTIONS_TTL_SEC=900
# Per-user sliding-window limits (per server instance; use Redis at scale)
# RATE_LIMIT_CATALOG_SEARCH_PER_MIN=45
# RATE_LIMIT_ANALYZE_PER_MIN=30
# RATE_LIMIT_RESTRICTIONS_PER_MIN=420
# RATE_LIMIT_KEYWORD_SEARCH_PER_MIN=40
# RATE_LIMIT_UPLOAD_PER_MIN=12
# Optional dev origins for LAN/browser testing (comma-separated)
# Example: ALLOWED_DEV_ORIGINS=http://10.0.0.217:3000,http://10.0.0.217:3001
ALLOWED_DEV_ORIGINS=
