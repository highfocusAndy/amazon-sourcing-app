generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  passwordHash         String
  name                 String?
  createdAt            DateTime @default(now())
  /// End of signup trial (set on register). Legacy users without this field get a computed grace in code.
  trialEndsAt          DateTime?
  /// Extended access from a redeemed promo code.
  promoAccessUntil     DateTime?
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  /// Stripe subscription status: none | active | trialing | past_due | canceled | unpaid | incomplete
  subscriptionStatus   String   @default("none")
  /// Selected paid plan: starter | pro (promo/trial users default to starter)
  subscriptionPlan     String   @default("starter")
  amazonAccount        AmazonAccount?
  explorerFilterSettings UserExplorerFilters?
  preferences          UserPreferences?
  passkeys             PasskeyCredential[]
  promoRedemptions     PromoRedemption[]
  passwordResetTokens  PasswordResetToken[]
  monthlyUsage         UserMonthlyUsage[]
}

/// WebAuthn / passkey credentials (Face ID, Touch ID, device PIN, security keys).
model PasskeyCredential {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique
  publicKey    String
  counter      Int      @default(0)
  transports   String?
  label        String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

/// Short-lived WebAuthn challenges (registration / authentication).
model PasskeyChallenge {
  id        String   @id @default(cuid())
  challenge String   @unique
  kind      String
  payload   String
  expiresAt DateTime

  @@index([expiresAt])
}

/// One-time token exchanged for a NextAuth session after passkey verification.
model PasskeyLoginToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime

  @@index([expiresAt])
}

/// One-time link for forgot-password flow (hashed at rest; raw token only in email).
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model UserPreferences {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultSellerType         String   @default("FBA")   // "FBA" | "FBM"
  defaultShippingCostFbm    Float    @default(0)
  catalogPageSize           Int      @default(20)      // 10–100 (smaller default = fewer Catalog API GETs per screen)
  marketplaceId             String?  // e.g. ATVPDKIKX0DER (US), A2EUQ1WTGCTBG2 (CA), A1AM78C64UM0Y8 (MX)
  updatedAt                 DateTime @updatedAt
}

model AmazonAccount {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Optional legacy display — prefer SP-API OAuth for seller access.
  amazonEmail         String?
  amazonPasswordHash  String?
  /// AES-GCM encrypted LWA refresh token (SP-API website OAuth).
  spRefreshTokenEnc   String?
  /// Selling partner ID from OAuth (same as SELLER_ID for that account).
  sellerId            String?
  /// Display name from Sellers API (marketplace participations store name).
  amazonStoreName     String?
  /// Marketplace used when starting OAuth (e.g. user preference).
  oauthMarketplaceId  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model UserExplorerFilters {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  showKeyword       Boolean  @default(true)
  showSort          Boolean  @default(true)
  showBsr           Boolean  @default(true)
  showMinRoi        Boolean  @default(false)
  showMinProfit     Boolean  @default(false)
  showFbaFbm        Boolean  @default(false)
  showRestriction   Boolean  @default(false)
  showPriceRange    Boolean  @default(false)
  updatedAt         DateTime @updatedAt
}

/// Shared SP-API response cache (catalog search pages, catalog items, keyword search, analysis snapshots).
model ApiResponseCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  payload   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

/// Promo codes extend `promoAccessUntil` for testers / partners (see /api/promo/redeem).
model PromoCode {
  id               String   @id @default(cuid())
  code             String   @unique
  label            String?
  grantsDays       Int
  maxRedemptions   Int?
  redemptionCount  Int      @default(0)
  expiresAt        DateTime?
  active           Boolean  @default(true)
  /// If true, the same user can redeem again to stack more days (for QA). Normal launch codes stay false.
  allowRepeatRedemption Boolean @default(false)
  createdAt        DateTime @default(now())
  redemptions      PromoRedemption[]
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  redeemedAt  DateTime  @default(now())

  @@unique([promoCodeId, userId])
  @@index([userId])
}

/// Monthly per-user endpoint usage counters for plan limits.
model UserMonthlyUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// UTC month key, e.g. "2026-03"
  periodKey String
  /// Metric id (analyze, analyze_offers, catalog_search, keyword_search, restrictions)
  metric    String
  used      Int      @default(0)
  /// Snapshot of limit at write time (null = unlimited).
  limit     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, periodKey, metric])
  @@index([userId, periodKey])
}
